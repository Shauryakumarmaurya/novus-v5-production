# Copy this to .env and fill in your real values. Do NOT commit .env.

# ── Auth (REQUIRED in production — the app fails closed without it) ──────────
# Clients must send this value in the X-API-Key header.
NOVUS_API_KEY=replace_me
# Set to "production" on servers to enforce auth (also honored: FLASK_ENV)
NOVUS_ENV=development

# ── LLM / embedding APIs ─────────────────────────────────────────────────────
DEEPSEEK_API_KEY=replace_me
GEMINI_API_KEY=replace_me
# Voyage AI — embeddings for the RAG store (voyage-finance-2)
VOYAGE_API_KEY=replace_me
# Tavily — live signal pipeline web search (optional; signals degrade gracefully)
TAVILY_API_KEY=replace_me

# Optional: Financial Modeling Prep API (if used)
FMP_API_KEY=replace_me

# ── Redis (use REDIS_URL in production if available) ─────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:6379/0

# Queue name
RQ_QUEUE_NAME=financial_analysis

# ── Web security ─────────────────────────────────────────────────────────────
# Comma-separated allowed CORS origins (set to your production domain)
CORS_ORIGINS=http://localhost:3000,http://localhost:5001,http://127.0.0.1:5001
# Comma-separated folder roots /ingest_local may read from
# ALLOWED_INGEST_PATHS=/data/uploads
# Upload limits
MAX_UPLOAD_MB=100
MAX_UPLOAD_FILES=10
# Copilot chat hard timeout (seconds)
CHAT_TIMEOUT_S=600

# ── Scrapers ─────────────────────────────────────────────────────────────────
# Screener.in session cookies (from your browser after login) — used by
# scrapper/scrape_screener_docs.py for bulk document downloads
SCREENER_SESSIONID=
SCREENER_CSRFTOKEN=

# ── Services ─────────────────────────────────────────────────────────────────
# Gotenberg PDF service (docker-compose provides http://gotenberg:3000)
GOTENBERG_URL=http://gotenberg:3000

# Logging
ENABLE_DEEPSEEK_DEBUG_LOGS=false
ENABLE_GEMINI_DEBUG_LOGS=false
